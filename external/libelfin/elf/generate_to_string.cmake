# CMake script to generate to_string.cc
# This is more portable than using bash commands

set(OUTPUT_FILE "${OUTPUT_DIR}/to_string.cc")

# Write header
file(WRITE "${OUTPUT_FILE}" "// Automatically generated by CMake\n")
file(APPEND "${OUTPUT_FILE}" "// DO NOT EDIT\n")
file(APPEND "${OUTPUT_FILE}" "\n")
file(APPEND "${OUTPUT_FILE}" "#include \"data.hh\"\n")
file(APPEND "${OUTPUT_FILE}" "#include \"to_hex.hh\"\n")
file(APPEND "${OUTPUT_FILE}" "#include <string>\n")
file(APPEND "${OUTPUT_FILE}" "\n")
file(APPEND "${OUTPUT_FILE}" "ELFPP_BEGIN_NAMESPACE\n")
file(APPEND "${OUTPUT_FILE}" "\n")

# Run Python script and append its output
execute_process(
    COMMAND ${Python3_EXECUTABLE} "${SOURCE_DIR}/enum-print.py" 
            -u --hex --no-type --mask shf --mask pf 
            -x loos -x hios -x loproc -x hiproc
    INPUT_FILE "${SOURCE_DIR}/data.hh"
    OUTPUT_VARIABLE ENUM_OUTPUT
    RESULT_VARIABLE ENUM_RESULT
)

if(NOT ENUM_RESULT EQUAL 0)
    message(FATAL_ERROR "Failed to run enum-print.py")
endif()

file(APPEND "${OUTPUT_FILE}" "${ENUM_OUTPUT}")

# Write footer
file(APPEND "${OUTPUT_FILE}" "\n")
file(APPEND "${OUTPUT_FILE}" "ELFPP_END_NAMESPACE\n")

message(STATUS "Generated to_string.cc")
